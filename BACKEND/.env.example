# Server
NODE_ENV=development
PORT=8000
HOST=0.0.0.0

# Database
MONGODB_URI=mongodb://localhost:27017/nexus-crm

# Auth
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret
REFRESH_TOKEN_EXPIRY=10d

# Frontend origins allowed to call this API with credentials.
# For Render production, set this to your Vercel URL, for example:
# CORS_ORIGIN=https://nexus-customer-relationship-managem.vercel.app
# Multiple origins are comma-separated:
# CORS_ORIGIN=http://localhost:3000,https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:3000,https://nexus-customer-relationship-managem.vercel.app

# Optional: only enable this if you want all *.vercel.app preview URLs to call the API.
CORS_ALLOW_VERCEL_PREVIEWS=false
