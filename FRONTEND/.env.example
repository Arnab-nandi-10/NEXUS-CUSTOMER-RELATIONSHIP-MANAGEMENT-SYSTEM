# Environment variables for the CRM frontend
# Copy this file to .env and update with your values

# API URL
VITE_API_URL=https://mini-crm-backend-tf6f.onrender.com/api/v1

# App Configuration
VITE_APP_NAME=Nexus CRM
VITE_APP_URL=https://nexus-customer-relationship-managem.vercel.app

# Optional: Analytics
# Vercel Web Analytics and Speed Insights are wired in code.
# Enable both in the Vercel dashboard after deployment.

# Optional: Error Tracking
# VITE_SENTRY_DSN=your-sentry-dsn
